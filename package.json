{
  "name": "x402-cannastack",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0 --no-error-on-unmatched-pattern",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed --workers=1 --project=chromium",
    "test:e2e:demo": "PLAYWRIGHT_DEMO=1 PLAYWRIGHT_TILE_WINDOWS=1 DEMO_SLOWMO=750 playwright test tests/cannastack-demo.spec.ts --headed --workers=2 --fully-parallel --project=chromium --reporter=line",
    "test:e2e:ui": "playwright test --ui",
    "preflight": "node scripts/preflight.mjs",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed-metros.ts",
    "crawl": "tsx scripts/crawl.ts",
    "smoke:prod": "node scripts/smoke-prod.mjs"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "dotenv": "^17.4.2",
    "next": "^15.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^10.4.0",
    "eslint-config-next": "^16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  }
}
