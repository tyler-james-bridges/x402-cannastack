# Neon Postgres
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Crawl auth (required — /api/crawl returns 503 without it).
# Vercel sends this automatically as "Authorization: Bearer $CRON_SECRET" on cron runs.
CRON_SECRET=

# x402 payment metering (Base / USDC) — Base is the primary chain.
# Wallet that receives per-request payments
CANNASTACK_PAY_TO=
# Active settlement chain: "base" (default) or "abstract"
X402_NETWORK=base
# Base mainnet facilitator (must advertise eip155:8453 in /supported,
# or @x402/next throws RouteConfigurationError). payai supports exact on
# Base mainnet with no auth; swap to Coinbase CDP if you have keys.
X402_FACILITATOR_BASE=https://facilitator.payai.network
# Override the Abstract facilitator if X402_NETWORK=abstract
X402_FACILITATOR_ABSTRACT=https://facilitator.x402.abs.xyz
# Set to 1 to bypass metering and serve everything free (legacy preview)
X402_PREVIEW_MODE=

# Browser wallet connect (client-side). Public-only value, safe to expose.
# WalletConnect / Reown project id enables the WalletConnect (mobile/QR)
# connector. Leave empty to ship with just the injected (MetaMask) and
# Coinbase Wallet connectors. Get one free at https://cloud.reown.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
