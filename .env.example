# Neon Postgres
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Crawl auth (required — /api/crawl returns 503 without it).
# Vercel sends this automatically as "Authorization: Bearer $CRON_SECRET" on cron runs.
CRON_SECRET=

# Crawl queue worker (/api/crawl enqueues, /api/crawl/worker executes)
# Minutes before a claimed-but-unfinished run is presumed stuck and reclaimed
CRAWL_STUCK_AFTER_MINUTES=15
# Claim attempts before a stuck run is marked failed
CRAWL_MAX_ATTEMPTS=3
# Worker time budget per invocation (ms); must leave headroom under maxDuration
CRAWL_WORKER_BUDGET_MS=240000
# Set to 1 to crawl Leafly too (leave unset until their public API access is
# confirmed — see docs/verification/leafly-readiness.md)
CRAWL_ENABLE_LEAFLY=
# Local dev/test only: route the Neon driver's HTTP queries to a local proxy
# (e.g. http://localhost:4444/sql in front of plain Postgres). Never set in prod.
NEON_HTTP_FETCH_ENDPOINT=

# x402 payment metering (Abstract / USDC)
# Wallet that receives per-request payments
CANNASTACK_PAY_TO=
# Override the Abstract facilitator if needed
X402_FACILITATOR_ABSTRACT=https://facilitator.x402.abs.xyz
# Set to 1 to bypass metering and serve everything free (legacy preview)
X402_PREVIEW_MODE=
